{
  "name": "@navsahyog/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:apply": "wrangler d1 execute navsahyog_db --local --file=../../db/schema.sql",
    "db:seed": "wrangler d1 execute navsahyog_db --local --file=../../db/seed.sql",
    "db:reset": "pnpm db:drop && pnpm db:apply && pnpm db:seed",
    "db:drop": "rm -rf .wrangler/state/v3/d1"
  },
  "dependencies": {
    "@navsahyog/shared": "workspace:*",
    "hono": "^4.6.12"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "wrangler": "^3.95.0"
  }
}
